{
  "name": "@bg7ldb/chinese-telecode",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "sync:corpora": "node scripts/sync-corpora-manifest.mjs",
    "sync:vendor": "node scripts/sync-opencc-vendor.mjs",
    "prepare:runtime": "npm run sync:corpora && npm run sync:vendor",
    "predev": "npm run prepare:runtime",
    "dev": "vite --host 127.0.0.1",
    "preserve": "npm run prepare:runtime",
    "serve": "node server.mjs",
    "build": "npm run prepare:runtime && vite build",
    "preview": "vite preview --host 127.0.0.1"
  },
  "devDependencies": {
    "vite": "^5.4.11"
  },
  "dependencies": {
    "opencc-js": "^1.3.1"
  }
}
